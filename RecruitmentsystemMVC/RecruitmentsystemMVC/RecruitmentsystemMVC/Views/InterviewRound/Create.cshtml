@model RecruitmentsystemMVC.Models.DTOs.CreateInterviewRoundDTO
@{
    ViewData["Title"] = "Create Interview Round";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2 text-primary"></i>Create Interview Round</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-3">
                        <label asp-for="RoundName" class="form-label fw-bold"></label>
                        <input asp-for="RoundName" class="form-control" placeholder="e.g. Technical Round 1" />
                        <span asp-validation-for="RoundName" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Create Round</button>
                        <a asp-action="Index" class="btn btn-light">Back to List</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
