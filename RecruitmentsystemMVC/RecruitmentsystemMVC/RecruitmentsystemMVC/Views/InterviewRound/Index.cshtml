@model RecruitmentsystemMVC.Models.PaginatedList<RecruitmentsystemMVC.Models.DTOs.InterviewRoundDTO>
@inject RecruitmentsystemMVC.Helpers.RoleHelper RoleHelper
@{
    ViewData["Title"] = "Interview Workflow";
}

<div class="card p-4 shadow-sm border-0 rounded-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Interview Workflow</h4>
            <p class="text-muted small mb-0">Define the core interview rounds for your recruitment process</p>
        </div>
        @if (RoleHelper.CanManageInterviewRounds())
        {
            <button class="btn btn-primary d-flex align-items-center px-3 py-2 rounded-3" onclick="openAddModal()">
                <i class="bi bi-plus-lg me-2"></i> Add Round
            </button>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-hover w-100 align-middle">
            <thead class="bg-light">
                <tr>
                    <th class="ps-3 border-0 py-3 text-uppercase small fw-bold text-muted" style="width: 100px;">ID</th>
                    <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Round Name</th>
                    @if (RoleHelper.CanManageInterviewRounds())
                    {
                        <th class="text-end pe-3 border-0 py-3 text-uppercase small fw-bold text-muted">Actions</th>
                    }
                </tr>
            </thead>
            <tbody class="border-top-0">
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3">
                            <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary px-3 py-2">
                                #@item.Id
                            </span>
                        </td>
                        <td class="fw-bold text-dark">@item.Name</td>
                        @if (RoleHelper.CanManageInterviewRounds())
                        {
                            <td class="text-end pe-3">
                                <div class="d-flex justify-content-end gap-2">
                                    <button class="btn btn-sm btn-white border shadow-sm" onclick="editRound(@item.Id, '@item.Name')" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-white border shadow-sm text-danger" onclick="deleteRound(@item.Id)" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <div class="text-muted small">
            Showing <span class="fw-bold">@Model.Count</span> rounds
        </div>
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link rounded-start-3 px-3" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)">
                        <i class="bi bi-chevron-left me-1"></i> Previous
                    </a>
                </li>
                <li class="page-item active"><a class="page-link px-3">@Model.PageIndex</a></li>
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link rounded-end-3 px-3" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)">
                        Next <i class="bi bi-chevron-right ms-1"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<!-- Round Modal -->
<div class="modal fade" id="addRoundModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="fw-bold fs-5" id="modalTitle">Define Interview Round</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="roundForm">
                    <input type="hidden" name="Id" id="roundId">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Round Name</label>
                        <input type="text" name="RoundName" id="roundName" class="form-control rounded-3 py-2 shadow-none border-light-subtle" required placeholder="e.g. Technical Screening">
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary px-4 rounded-3" onclick="submitRound()">Save Round</button>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8f9fa; }
</style>

@section Scripts {
    <script>
        function openAddModal() {
            $('#roundForm')[0].reset();
            $('#roundId').val('');
            $('#modalTitle').text('Define Interview Round');
            $('#addRoundModal').modal('show');
        }

        function editRound(id, name) {
            $('#roundId').val(id);
            $('#roundName').val(name);
            $('#modalTitle').text('Edit Interview Round');
            $('#addRoundModal').modal('show');
        }

        function submitRound() {
            const id = $('#roundId').val();
            const url = id ? '/InterviewRound/Edit/' + id : '/InterviewRound/Create';
            const data = $('#roundForm').serialize();
            
            $.post(url, data, function(res) {
                if (res.success) {
                    Swal.fire({ title: 'Success', text: res.message, icon: 'success', timer: 1500, showConfirmButton: false }).then(() => location.reload());
                } else {
                    Swal.fire('Error', res.message || 'Failed to save round.', 'error');
                }
            });
        }

        function deleteRound(id) {
            Swal.fire({
                title: 'Delete Round?',
                text: "Removing this round will delete all associated interview configurations.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6e7881',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/InterviewRound/Delete/' + id, function(res) {
                        if (res.success) {
                            Swal.fire({ title: 'Deleted', text: 'Round removed.', icon: 'success', timer: 1500, showConfirmButton: false }).then(() => location.reload());
                        } else {
                            Swal.fire('Error', res.message || 'Failed to delete.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
