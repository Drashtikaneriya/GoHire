@model RecruitmentsystemMVC.Models.PaginatedList<RecruitmentsystemMVC.Models.DTOs.UserDTO>
@{
    ViewData["Title"] = "User Management";
}

<div class="card p-4 shadow-sm border-0 rounded-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">System Users</h4>
            <p class="text-muted small mb-0">Manage and monitor all recruitment system users</p>
        </div>
        <a asp-action="Create" class="btn btn-primary d-flex align-items-center px-3 py-2 rounded-3">
            <i class="bi bi-person-plus me-2"></i> Add New User
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 border-0 shadow-sm" role="alert">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4 border-0 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover w-100 align-middle">
            <thead class="bg-light">
                <tr>
                    <th class="ps-3 border-0 py-3 text-uppercase small fw-bold text-muted">Full Name</th>
                    <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Email</th>
                    <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Phone</th>
                    <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Role</th>
                    <th class="text-end pe-3 border-0 py-3 text-uppercase small fw-bold text-muted">Actions</th>
                </tr>
            </thead>
            <tbody class="border-top-0">
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="ps-3">
                            <div class="d-flex align-items-center">
                                <div class="avatar-sm me-3 bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; font-weight: 600;">
                                    @((user.FullName?.Length >= 1) ? user.FullName.Substring(0, 1).ToUpper() : "U")
                                </div>
                                <span class="fw-semibold">@user.FullName</span>
                            </div>
                        </td>
                        <td class="text-muted">@user.Email</td>
                        <td>@user.Phone</td>
                        <td>
                            <span class="badge rounded-pill bg-light text-dark border px-3">@user.Role</span>
                        </td>
                        <td class="text-end pe-3">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-white border shadow-sm text-primary" title="Edit">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <button class="btn btn-sm btn-white border shadow-sm text-danger" onclick="deleteUser(@user.Id)" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <div class="text-muted small">
            Showing <span class="fw-bold">@Model.Count</span> of <span class="fw-bold text-dark">records</span>
        </div>
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link rounded-start-3 px-3" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)">
                        <i class="bi bi-chevron-left me-1"></i> Previous
                    </a>
                </li>
                <li class="page-item active"><a class="page-link px-3">@Model.PageIndex</a></li>
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link rounded-end-3 px-3" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)">
                        Next <i class="bi bi-chevron-right ms-1"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<style>
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8f9fa; }
    .tiny { font-size: 0.7rem; }
</style>

@section Scripts {
    <script>
        function toggleStatus(id) {
            $.post('/User/ToggleStatus/' + id, function(res) {
                if (res.success) {
                    Swal.fire({
                        title: 'Updated!',
                        text: res.message,
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => location.reload());
                } else {
                    Swal.fire('Error', res.message, 'error');
                }
            });
        }

        function deleteUser(id) {
            Swal.fire({
                title: 'Are you sure?',
                text: "User will be permanently deleted!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6e7881',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/User/Delete/' + id, function(res) {
                        if (res.success) {
                            Swal.fire({ title: 'Deleted!', text: res.message, icon: 'success', timer: 1500, showConfirmButton: false }).then(() => location.reload());
                        } else {
                            if (res.isHtml) {
                                Swal.fire({ title: 'Cannot Delete!', html: res.message, icon: 'error' });
                            } else {
                                Swal.fire('Failed!', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }
    </script>
}
