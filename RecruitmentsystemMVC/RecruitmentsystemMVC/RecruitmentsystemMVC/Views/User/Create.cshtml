@model RecruitmentsystemMVC.Models.DTOs.CreateUserDTO
@{
    ViewData["Title"] = "Create User";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card p-4 shadow-sm border-0 rounded-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold mb-0">Create New User</h4>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-2"></i> Back to List
                </a>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mb-4">
                    <div asp-validation-summary="All" class="text-danger small mb-0"></div>
                </div>
            }

            <form asp-action="Create" method="post">
                <div class="row g-3">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FullName" class="form-label fw-medium text-dark small mb-2">Full Name <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-person text-muted"></i></span>
                            <input asp-for="FullName" class="form-control bg-light border-start-0 ps-0" placeholder="John Doe" required />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small mt-1"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label fw-medium text-dark small mb-2">Email Address <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                            <input asp-for="Email" type="email" class="form-control bg-light border-start-0 ps-0" placeholder="name@example.com" required />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small mt-1"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Password" class="form-label fw-medium text-dark small mb-2">Password <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
                            <input asp-for="Password" type="password" class="form-control bg-light border-start-0 ps-0" placeholder="••••••••" required />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small mt-1"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label fw-medium text-dark small mb-2">Phone Number</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-phone text-muted"></i></span>
                            <input asp-for="Phone" class="form-control bg-light border-start-0 ps-0" placeholder="+1 234 567 890" />
                        </div>
                        <span asp-validation-for="Phone" class="text-danger small mt-1"></span>
                    </div>

                    <div class="col-md-12 mb-4">
                        <label asp-for="RoleId" class="form-label fw-medium text-dark small mb-2">Assign Role <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-shield-lock text-muted"></i></span>
                            <select asp-for="RoleId" class="form-select bg-light border-start-0 ps-0" required>
                                <option value="" disabled selected>-- Select a System Role --</option>
                                @if (ViewBag.Roles != null)
                                {
                                    foreach (var role in (List<RecruitmentsystemMVC.Models.DTOs.RoleDTO>)ViewBag.Roles)
                                    {
                                        <option value="@role.Id">@role.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <span asp-validation-for="RoleId" class="text-danger small mt-1"></span>
                    </div>
                </div>

                <div class="border-top pt-4 d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save me-2"></i> Save User
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
