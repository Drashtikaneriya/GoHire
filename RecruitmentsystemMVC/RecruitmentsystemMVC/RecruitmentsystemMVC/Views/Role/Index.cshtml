@model RecruitmentsystemMVC.Models.PaginatedList<RecruitmentsystemMVC.Models.DTOs.RoleDTO>
@{
    ViewData["Title"] = "System Roles";
}

<div class="card p-4 shadow-sm border-0 rounded-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Role Management</h4>
            <p class="text-muted small mb-0">Define and manage system access permissions</p>
        </div>
        <button class="btn btn-primary d-flex align-items-center px-3 py-2 rounded-3" data-bs-toggle="modal" data-bs-target="#addRoleModal">
            <i class="bi bi-shield-plus me-2"></i> Add Role
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover w-100 align-middle">
            <thead class="bg-light">
                <tr>
                    <th class="ps-3 border-0 py-3 text-uppercase small fw-bold text-muted">Role Name</th>
                    <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Control Level</th>
                    <th class="text-end pe-3 border-0 py-3 text-uppercase small fw-bold text-muted">Actions</th>
                </tr>
            </thead>
            <tbody class="border-top-0">
                @foreach (var r in Model)
                {
                    <tr>
                        <td class="ps-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                                    <i class="bi bi-shield-lock"></i>
                                </div>
                                <span class="fw-bold text-dark">@r.Name</span>
                            </div>
                        </td>
                        <td><span class="badge rounded-pill bg-light text-dark border px-3">Full Control</span></td>
                        <td class="text-end pe-3">
                             <button class="btn btn-sm btn-white border shadow-sm text-danger" onclick="deleteRole(@r.Id)" title="Delete">
                                 <i class="bi bi-trash"></i>
                             </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <div class="text-muted small">
            Displaying <span class="fw-bold">@Model.Count</span> active roles
        </div>
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link rounded-start-3 px-3" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)">
                        <i class="bi bi-chevron-left me-1"></i> Previous
                    </a>
                </li>
                <li class="page-item active"><a class="page-link px-3">@Model.PageIndex</a></li>
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link rounded-end-3 px-3" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)">
                        Next <i class="bi bi-chevron-right ms-1"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<!-- Add Role Modal -->
<div class="modal fade" id="addRoleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="fw-bold fs-5">Create System Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addRoleForm">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Role Name</label>
                        <input type="text" name="Name" class="form-control rounded-3 py-2 shadow-none border-light-subtle" required placeholder="e.g. HR_MANAGER">
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary px-4 rounded-3" onclick="submitAddRole()">Save Role</button>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8f9fa; }
</style>

@section Scripts {
    <script>
        function submitAddRole() {
            const data = $('#addRoleForm').serialize();
            $.post('/Role/Create', data, function(res) {
                if (res.success) {
                    Swal.fire({ title: 'Created', text: 'Role added successfully', icon: 'success', timer: 1500, showConfirmButton: false }).then(() => location.reload());
                } else {
                    Swal.fire('Error', 'Failed to add role', 'error');
                }
            });
        }

        function deleteRole(id) {
             Swal.fire({
                title: 'Delete Role?',
                text: "Are you sure you want to delete this system role?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6e7881',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Role/Delete/' + id, function(res) {
                        if (res.success) {
                            Swal.fire({ title: 'Deleted', text: 'Role removed', icon: 'success', timer: 1500, showConfirmButton: false }).then(() => location.reload());
                        } else {
                            Swal.fire('Failed!', 'This role is currently assigned to users and cannot be deleted.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
