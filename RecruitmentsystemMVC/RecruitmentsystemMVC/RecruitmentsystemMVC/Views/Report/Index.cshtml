@{
    ViewData["Title"] = "System Reports";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h3 class="fw-bold mb-1">Recruitment Intelligence</h3>
        <p class="text-muted small">Data-driven insights for your hiring process</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-primary btn-sm" onclick="window.print()">
            <i class="bi bi-printer me-2"></i> Print Report
        </button>
        <button class="btn btn-primary btn-sm">
            <i class="bi bi-download me-2"></i> Export CSV
        </button>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Key Metrics -->
    <div class="col-md-3">
        <div class="card p-3 border-0 shadow-sm rounded-4 h-100">
            <div class="d-flex align-items-center mb-3">
                <div class="stat-icon-sm bg-primary-soft me-3"><i class="bi bi-people"></i></div>
                <h6 class="text-muted mb-0 font-extrabold">Total Users</h6>
            </div>
            <h2 class="fw-bold">@ViewBag.TotalUsers</h2>
            <div class="progress mt-2" style="height: 6px;">
                <div class="progress-bar bg-primary" style="width: 100%;"></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 border-0 shadow-sm rounded-4 h-100">
            <div class="d-flex align-items-center mb-3">
                <div class="stat-icon-sm bg-success-soft me-3"><i class="bi bi-briefcase"></i></div>
                <h6 class="text-muted mb-0">Active Jobs</h6>
            </div>
            <h2 class="fw-bold">@ViewBag.ActiveJobs</h2>
            <div class="progress mt-2" style="height: 6px;">
                <div class="progress-bar bg-success" style="width: 75%;"></div>
            </div>
        </div>
    </div>
     <div class="col-md-3">
        <div class="card p-3 border-0 shadow-sm rounded-4 h-100">
            <div class="d-flex align-items-center mb-3">
                <div class="stat-icon-sm bg-warning-soft me-3"><i class="bi bi-file-earmark-text"></i></div>
                <h6 class="text-muted mb-0">Applications</h6>
            </div>
            <h2 class="fw-bold">@ViewBag.TotalApplications</h2>
            <div class="progress mt-2" style="height: 6px;">
                <div class="progress-bar bg-warning" style="width: 60%;"></div>
            </div>
        </div>
    </div>
     <div class="col-md-3">
        <div class="card p-3 border-0 shadow-sm rounded-4 h-100">
            <div class="d-flex align-items-center mb-3">
                <div class="stat-icon-sm bg-info-soft me-3"><i class="bi bi-calendar-check"></i></div>
                <h6 class="text-muted mb-0">Interviews</h6>
            </div>
            <h2 class="fw-bold">@ViewBag.TotalInterviews</h2>
             <div class="progress mt-2" style="height: 6px;">
                <div class="progress-bar bg-info" style="width: 45%;"></div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Charts Section -->
    <div class="col-lg-8">
        <div class="card p-4 border-0 shadow-sm rounded-4">
            <h5 class="fw-bold mb-4">Application Trends</h5>
            <div style="height: 350px;">
                <canvas id="applicationTrendChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card p-4 border-0 shadow-sm rounded-4">
             <h5 class="fw-bold mb-4">Review Status</h5>
             <div style="height: 250px;">
                 <canvas id="reviewStatusChart"></canvas>
             </div>
             <div class="mt-4">
                 <div class="d-flex justify-content-between mb-2 small">
                     <span><i class="bi bi-circle-fill text-warning me-2"></i> Pending</span>
                     <span class="fw-bold">@ViewBag.PendingApps</span>
                 </div>
                 <div class="d-flex justify-content-between mb-2 small">
                     <span><i class="bi bi-circle-fill text-success me-2"></i> Accepted</span>
                     <span class="fw-bold">@ViewBag.AcceptedApps</span>
                 </div>
                 <div class="d-flex justify-content-between mb-2 small">
                     <span><i class="bi bi-circle-fill text-danger me-2"></i> Rejected</span>
                     <span class="fw-bold">@ViewBag.RejectedApps</span>
                 </div>
             </div>
        </div>
    </div>
</div>

<style>
    .bg-primary-soft { background-color: #f0f4ff; color: #5541D7; }
    .bg-success-soft { background-color: #f0fdf4; color: #22c55e; }
    .bg-warning-soft { background-color: #fffbeb; color: #f59e0b; }
    .bg-info-soft { background-color: #eff6ff; color: #3b82f6; }
    .stat-icon-sm { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem;}
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Monthly Trend Chart
        const trendCtx = document.getElementById('applicationTrendChart').getContext('2d');
        new Chart(trendCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.MonthlyAppLabels)),
                datasets: [{
                    label: 'Applications Received',
                    data: @Html.Raw(Json.Serialize(ViewBag.MonthlyAppData)),
                    borderColor: '#5541D7',
                    tension: 0.4,
                    fill: true,
                    backgroundColor: 'rgba(85, 65, 215, 0.05)'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { 
                    y: { beginAtZero: true, grid: { borderDash: [5, 5] } },
                    x: { grid: { display: false } }
                }
            }
        });

        // Review Status Doughnut
        const statusCtx = document.getElementById('reviewStatusChart').getContext('2d');
        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: ['Pending', 'Accepted', 'Rejected'],
                datasets: [{
                    data: [@ViewBag.PendingApps, @ViewBag.AcceptedApps, @ViewBag.RejectedApps],
                    backgroundColor: ['#f59e0b', '#22c55e', '#ef4444'],
                    borderWidth: 0,
                    cutout: '80%'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } }
            }
        });
        
        // Job Distribution (Bar)
        // You could add another canvas in the UI for this if needed.
    </script>
}
