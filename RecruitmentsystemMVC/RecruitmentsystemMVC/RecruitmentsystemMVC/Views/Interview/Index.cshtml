@model RecruitmentsystemMVC.Models.PaginatedList<RecruitmentsystemMVC.Models.DTOs.InterviewDTO>
@inject RecruitmentsystemMVC.Helpers.RoleHelper RoleHelper
@{
    ViewData["Title"] = "Interviews Management";
}

<div class="card p-4 shadow-sm border-0 rounded-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Interview Sessions</h4>
            <p class="text-muted small mb-0">Monitor and manage candidate assessment schedules</p>
        </div>
        @if (RoleHelper.CanManageInterviews())
        {
            <a asp-action="Schedule" class="btn btn-primary d-flex align-items-center px-3 py-2 rounded-3">
                <i class="bi bi-calendar-plus me-2"></i> Schedule Interview
            </a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover w-100 align-middle">
            <thead class="bg-light">
                <tr>
                    <th class="ps-3 border-0 py-3 text-uppercase small fw-bold text-muted">Candidate & Job</th>
                    <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Interviewer</th>
                    <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Schedule</th>
                    <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Interview Type</th>
                    <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Result</th>
                    @if (RoleHelper.IsHR() || RoleHelper.IsAdmin())
                    {
                        <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Interviewer Notes</th>
                    }
                    <th class="text-end pe-3 border-0 py-3 text-uppercase small fw-bold text-muted">Actions</th>
                </tr>
            </thead>
            <tbody class="border-top-0">
                @foreach (var i in Model)
                {
                    <tr>
                        <td class="ps-3">
                            <div class="fw-bold text-dark">@i.CandidateName</div>
                            <div class="text-muted small">@i.JobTitle</div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-person-badge me-2 text-muted"></i>
                                <span class="small fw-medium">@i.InterviewerName</span>
                            </div>
                        </td>
                        <td>
                            <div class="small">
                                <div class="fw-bold">@i.InterviewDate.ToString("MMM dd, yyyy")</div>
                                <div class="text-muted">@i.InterviewDate.ToString("hh:mm tt")</div>
                            </div>
                        </td>
                        <td>
                            <span class="badge rounded-pill bg-light text-dark border px-3">@i.RoundName</span>
                        </td>
                        <td>
                            @if (string.IsNullOrEmpty(i.Result) || i.Result == "Pending")
                            {
                                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 px-3 py-1 rounded-pill small">Pending</span>
                            }
                            else if (i.Result == "Selected" || i.Result == "Passed")
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-1 rounded-pill small">@i.Result</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-1 rounded-pill small">@i.Result</span>
                            }
                        </td>
                        @if (RoleHelper.IsHR() || RoleHelper.IsAdmin())
                        {
                            <td>
                                @if (!string.IsNullOrEmpty(i.Feedback))
                                {
                                    <span class="text-muted small" title="@i.Feedback">
                                        @(i.Feedback.Length > 30 ? i.Feedback.Substring(0, 27) + "..." : i.Feedback)
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small italic">No notes yet</span>
                                }
                            </td>
                        }
                        <td class="text-end pe-3">
                            <div class="d-flex justify-content-end gap-2">
                                @if (RoleHelper.IsInterviewer())
                                {
                                    <button class="btn btn-sm btn-outline-primary" onclick="openFeedbackModal(@i.Id)" title="Add Feedback">
                                        <i class="bi bi-chat-left-text"></i>
                                    </button>
                                }
                                @if (RoleHelper.IsHR())
                                {
                                    <button class="btn btn-sm btn-outline-success" onclick="openResultModal(@i.Id)" title="Set Result">
                                        <i class="bi bi-check-circle"></i>
                                    </button>
                                }
                                @if (RoleHelper.IsAdmin())
                                {
                                    <button class="btn btn-sm btn-white border shadow-sm text-danger" onclick="deleteInterview(@i.Id)" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <div class="text-muted small">
            Displaying <span class="fw-bold">@Model.Count</span> total interview records
        </div>
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link rounded-start-3 px-3" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)">
                        <i class="bi bi-chevron-left me-1"></i> Previous
                    </a>
                </li>
                <li class="page-item active"><a class="page-link px-3">@Model.PageIndex</a></li>
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link rounded-end-3 px-3" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)">
                        Next <i class="bi bi-chevron-right ms-1"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<!-- Feedback Modal -->
<div class="modal fade" id="feedbackModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom-0">
                <h5 class="fw-bold">Submit Interview Feedback</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="feedbackForm">
                    <input type="hidden" id="feedbackId">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Feedback Comments</label>
                        <textarea class="form-control rounded-3" id="feedbackText" rows="4" required placeholder="Observations about candidate..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary px-4" onclick="submitFeedback()">Save Feedback</button>
            </div>
        </div>
    </div>
</div>

<!-- Result Modal (HR) -->
<div class="modal fade" id="resultModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom-0">
                <h5 class="fw-bold">Set Interview Result</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="resultInterviewId">
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-success rounded-3 py-2" onclick="setResult('Selected')">Selected / Passed</button>
                    <button class="btn btn-outline-danger rounded-3 py-2" onclick="setResult('Rejected')">Rejected / Failed</button>
                    <button class="btn btn-outline-warning rounded-3 py-2" onclick="setResult('Pending')">On Hold / Pending</button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8f9fa; }
</style>

@section Scripts {
    <script>
        function openFeedbackModal(id) {
            $('#feedbackId').val(id);
            $('#feedbackText').val('');
            $('#feedbackModal').modal('show');
        }

        function submitFeedback() {
            const id = $('#feedbackId').val();
            const text = $('#feedbackText').val();
            if(!text) return Swal.fire('Error', 'Please enter feedback', 'error');

            $.post('/Interview/Feedback/' + id, { Feedback: text }, function(res) {
                if(res.success) {
                    Swal.fire({ title: 'Success', text: 'Feedback submitted.', icon: 'success', timer: 1500, showConfirmButton: false }).then(() => location.reload());
                } else {
                    Swal.fire('Error', res.message, 'error');
                }
            });
        }

        function openResultModal(id) {
            $('#resultInterviewId').val(id);
            $('#resultModal').modal('show');
        }

        function setResult(resValue) {
            const id = $('#resultInterviewId').val();
            $.post('/Interview/SubmitResult/' + id, { result: resValue }, function(res) {
                if(res.success) {
                    Swal.fire({ title: 'Success', text: 'Result updated to ' + resValue, icon: 'success', timer: 1500, showConfirmButton: false }).then(() => location.reload());
                } else {
                    Swal.fire('Error', res.message, 'error');
                }
            });
        }

        function deleteInterview(id) {
            Swal.fire({
                title: 'Delete Interview?',
                text: "This will permanently remove the interview record.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6e7881',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Interview/Delete/' + id, function(res) {
                        if (res.success) {
                            Swal.fire({ title: 'Deleted!', text: res.message || 'Interview record removed.', icon: 'success', timer: 1000, showConfirmButton: false }).then(() => location.reload());
                        } else {
                            Swal.fire('Failed!', res.message || 'Could not delete record.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
