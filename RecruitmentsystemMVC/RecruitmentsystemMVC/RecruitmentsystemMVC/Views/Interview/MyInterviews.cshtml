@model List<RecruitmentsystemMVC.Models.DTOs.InterviewDTO>
@{
    ViewData["Title"] = "My Scheduled Interviews";
}

<div class="container py-4">
    <div class="row mb-4 animate__animated animate__fadeInDown">
        <div class="col-lg-8">
            <h2 class="display-6 fw-bold text-primary mb-1">My Scheduled Interviews</h2>
            <p class="text-muted lead">Stay updated with your upcoming recruitment assessments and follow your journey.</p>
        </div>
        <div class="col-lg-4 text-lg-end d-flex align-items-center justify-content-lg-end mt-3 mt-lg-0">
            <span class="badge bg-soft-primary text-primary px-3 py-2 rounded-pill">
                <i class="bi bi-clock-history me-1"></i> Newest First
            </span>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 py-5 animate__animated animate__fadeInUp">
            <div class="card-body text-center py-5">
                <div class="mb-4">
                    <div class="bg-light rounded-circle d-inline-flex p-4">
                        <i class="bi bi-journal-x text-muted display-4"></i>
                    </div>
                </div>
                <h3 class="fw-bold text-dark">No interviews scheduled yet</h3>
                <p class="text-muted mx-auto mb-4" style="max-width: 400px;">
                    It looks like you don't have any upcoming interviews at the moment. We'll notify you once an interviewer schedules a session with you.
                </p>
                <a asp-action="Index" asp-controller="Home" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm">
                    <i class="bi bi-house-door me-1"></i> Back to Dashboard
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4 d-none d-md-flex align-items-stretch mb-4 animate__animated animate__fadeInUp">
            @foreach (var interview in Model.OrderByDescending(i => i.InterviewDate))
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden hover-shadow transition-all border-start border-4 border-primary">
                        <div class="card-body p-0">
                            <div class="row g-0 align-items-center">
                                <!-- Date Column -->
                                <div class="col-md-3 bg-light p-4 text-center border-end">
                                    <div class="text-uppercase text-primary fw-bold small mb-1">@interview.InterviewDate.ToString("MMMM")</div>
                                    <div class="display-5 fw-bold text-dark mb-0">@interview.InterviewDate.Day</div>
                                    <div class="text-muted">@interview.InterviewDate.DayOfWeek</div>
                                </div>
                                
                                <!-- Details Column -->
                                <div class="col-md-9 p-4">
                                    <div class="d-md-flex justify-content-between align-items-start">
                                        <div>
                                            <div class="d-flex align-items-center mb-2">
                                                <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-1 rounded-pill me-2">
                                                    Round ID: @interview.RoundId
                                                </span>
                                                <span class="badge bg-secondary bg-opacity-10 text-secondary px-3 py-1 rounded-pill">
                                                    @(string.IsNullOrEmpty(interview.Mode) ? "TBD" : interview.Mode) Mode
                                                </span>
                                            </div>
                                            <h4 class="fw-bold text-dark mb-1">
                                                @(string.IsNullOrEmpty(interview.JobTitle) ? "Interview Assessment" : interview.JobTitle)
                                            </h4>
                                            <div class="text-muted small mb-3">
                                                <i class="bi bi-person-workspace me-1"></i> Interviewer: @(string.IsNullOrEmpty(interview.InterviewerName) ? "Assigned Recruiter" : interview.InterviewerName)
                                            </div>
                                        </div>
                                        <div class="text-md-end mt-3 mt-md-0">
                                            <div class="mb-3">
                                                <div class="text-dark fw-bold h5 mb-0">
                                                    <i class="bi bi-clock me-1 text-primary"></i>
                                                    @interview.InterviewDate.ToString("hh:mm tt")
                                                </div>
                                                @if (interview.InterviewEnd.HasValue)
                                                {
                                                    <div class="text-muted small">to @interview.InterviewEnd.Value.ToString("hh:mm tt")</div>
                                                }
                                            </div>
                                            @if (interview.InterviewDate < DateTime.Now)
                                            {
                                                <span class="badge bg-light text-dark border px-3 py-2 rounded-3">
                                                    <i class="bi bi-check-circle-fill text-success me-1"></i> Concluded
                                                </span>
                                            }
                                            else
                                            {
                                                <button class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                                    <i class="bi bi-calendar-event me-1"></i> Add to Calendar
                                                </button>
                                            }
                                        </div>
                                    </div>
                                    
                                    <!-- Status indicator -->
                                    <div class="mt-3 pt-3 border-top d-flex justify-content-between align-items-center">
                                        <div class="d-flex align-items-center">
                                            <div class="small text-muted me-2">Application Status:</div>
                                            <div class="fw-bold small text-uppercase">@interview.Result</div>
                                        </div>
                                        <a href="#" class="btn btn-link btn-sm text-decoration-none p-0 fw-bold">
                                            View Details <i class="bi bi-chevron-right small"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Mobile View -->
        <div class="row g-3 d-md-none animate__animated animate__fadeInUp">
            @foreach (var interview in Model.OrderByDescending(i => i.InterviewDate))
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 p-3">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 text-center" style="width: 60px;">
                                <div class="small fw-bold">@interview.InterviewDate.ToString("MMM")</div>
                                <div class="h4 fw-bold mb-0">@interview.InterviewDate.Day</div>
                            </div>
                            <div class="text-end">
                                <span class="badge bg-soft-secondary text-secondary rounded-pill mb-1">Round @interview.RoundId</span>
                                <div class="fw-bold small">@interview.InterviewDate.ToString("hh:mm tt")</div>
                            </div>
                        </div>
                        <h5 class="fw-bold mb-1">@(string.IsNullOrEmpty(interview.JobTitle) ? "Interview Assessment" : interview.JobTitle)</h5>
                        <p class="text-muted small mb-3">Mode: @interview.Mode</p>
                        <button class="btn btn-primary w-100 rounded-pill">View Details</button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Styles {
    <style>
        .hover-shadow:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
        }
        .bg-soft-primary {
            background-color: rgba(13, 110, 253, 0.1);
        }
        .bg-soft-secondary {
            background-color: rgba(108, 117, 125, 0.1);
        }
        .transition-all {
            transition: all 0.3s ease;
        }
        .card-body {
            transition: background-color 0.2s ease;
        }
        .hover-shadow:hover .card-body {
            background-color: #fafbfc;
        }
    </style>
}
