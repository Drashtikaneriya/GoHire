@model RecruitmentsystemMVC.Models.DTOs.CreateApplicationDTO
@{
    ViewData["Title"] = "New Application";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 rounded-4 p-4">
            <div class="d-flex align-items-center mb-4">
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-circle me-3" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h4 class="fw-bold mb-0">Create Application</h4>
            </div>

            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label asp-for="JobId" class="form-label fw-semibold">Target Job Position</label>
                    <select asp-for="JobId" class="form-select" required>
                        <option value="">Select an open position</option>
                        @foreach (var job in (List<RecruitmentsystemMVC.Models.DTOs.JobDTO>)ViewBag.Jobs)
                        {
                            <option value="@job.Id">@job.Title (@job.CompanyName)</option>
                        }
                    </select>
                    <span asp-validation-for="JobId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CandidateId" class="form-label fw-semibold">Select Candidate</label>
                    <select asp-for="CandidateId" class="form-select" required>
                        <option value="">Search candidate name...</option>
                        @foreach (var c in (List<RecruitmentsystemMVC.Models.DTOs.UserDTO>)ViewBag.Candidates)
                        {
                            <option value="@c.Id">@c.FullName (@c.Email)</option>
                        }
                    </select>
                    <span asp-validation-for="CandidateId" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Upload Resume (Optional)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-file-earmark-pdf"></i></span>
                        <input type="file" name="resumeFile" class="form-control" accept=".pdf,.doc,.docx">
                    </div>
                    <div class="form-text">Accepted formats: PDF, DOC, DOCX</div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Create Application</button>
                </div>
            </form>
        </div>
    </div>
</div>
