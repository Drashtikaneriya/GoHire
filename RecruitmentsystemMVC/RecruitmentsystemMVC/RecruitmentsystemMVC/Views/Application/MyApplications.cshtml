@model IEnumerable<RecruitmentsystemMVC.Models.DTOs.ApplicationDTO>
@{
    ViewData["Title"] = "My Applications";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0 fw-bold"><i class="bi bi-journal-text me-2 text-primary"></i>My Job Applications</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="myAppsTable">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Job Title</th>
                        <th>Applied On</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold">@app.JobTitle</span>
                            </td>
                            <td>@app.AppliedDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (app.Status == "Shortlisted")
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">@app.Status</span>
                                }
                                else if (app.Status == "Rejected")
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3">@app.Status</span>
                                }
                                else if (app.Status == "Pending")
                                {
                                    <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3">@app.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3">@app.Status</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="Details" asp-route-id="@app.Id" class="btn btn-outline-primary btn-sm rounded-pill px-3">View Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#myAppsTable').DataTable({
                "paging": true,
                "lengthChange": false,
                "searching": true,
                "info": true,
                "autoWidth": false,
                "responsive": true
            });
        });
    </script>
}
