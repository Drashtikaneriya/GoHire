@model RecruitmentsystemMVC.Models.DTOs.ApplicationDTO
@{
    ViewData["Title"] = "Update Application Status";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 rounded-4 p-4">
            <div class="d-flex align-items-center mb-4">
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-circle me-3" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h4 class="fw-bold mb-0">Update Application Status</h4>
            </div>

            <div class="bg-light rounded p-3 mb-4">
                <div class="row g-2">
                    <div class="col-sm-6">
                        <small class="text-muted d-block">Candidate</small>
                        <span class="fw-bold">@Model.CandidateName</span>
                    </div>
                    <div class="col-sm-6">
                        <small class="text-muted d-block">Job Position</small>
                        <span class="fw-bold">@Model.JobTitle</span>
                    </div>
                </div>
            </div>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CandidateId" />
                <input type="hidden" asp-for="JobId" />

                <div class="mb-4">
                    <label asp-for="Status" class="form-label fw-semibold">Current Workflow Status</label>
                    <select asp-for="Status" class="form-select shadow-sm" required>
                        <option value="Applied">Applied / Pending Review</option>
                        <option value="Shortlisted">Shortlisted</option>
                        <option value="Interviewing">Interviewing</option>
                        <option value="Offered">Offer Extended</option>
                        <option value="Accepted">Accepted</option>
                        <option value="Rejected">Rejected</option>
                        <option value="OnHold">On Hold</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger small"></span>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>
