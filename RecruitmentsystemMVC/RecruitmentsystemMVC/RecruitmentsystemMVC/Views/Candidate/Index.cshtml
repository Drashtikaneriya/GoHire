@model RecruitmentsystemMVC.Models.PaginatedList<RecruitmentsystemMVC.Models.DTOs.UserDTO>
@{
    ViewData["Title"] = "Candidate Directory";
}

<div class="card p-4 shadow-sm border-0 rounded-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Registered Candidates</h4>
            <p class="text-muted small mb-0">View and manage all registered talent in the system</p>
        </div>
        <a asp-action="Create" class="btn btn-primary d-flex align-items-center px-3 py-2 rounded-3">
            <i class="bi bi-person-plus me-2"></i> Add Candidate
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover w-100 align-middle">
            <thead class="bg-light">
                <tr>
                    <th class="ps-3 border-0 py-3 text-uppercase small fw-bold text-muted">Candidate Details</th>
                    <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Email</th>
                    <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Phone</th>
                    <th class="text-end pe-3 border-0 py-3 text-uppercase small fw-bold text-muted">Actions</th>
                </tr>
            </thead>
            <tbody class="border-top-0">
                @foreach (var c in Model)
                {
                    <tr>
                        <td class="ps-3">
                            <div class="d-flex align-items-center">
                                <div class="avatar-sm me-3 bg-soft-purple text-purple rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px;">
                                    @((c.FullName?.Length >= 2) ? c.FullName.Substring(0,2).ToUpper() : (c.FullName?.ToUpper() ?? "U"))
                                </div>
                                <span class="fw-semibold">@c.FullName</span>
                            </div>
                        </td>
                        <td class="text-muted small">@c.Email</td>
                        <td class="small">@c.Phone</td>
                        <td class="text-end pe-3">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-white border shadow-sm text-primary" title="Edit">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <button class="btn btn-sm btn-white border shadow-sm text-danger" onclick="deleteCandidate(@c.Id)" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <div class="text-muted small">
            Exploring <span class="fw-bold">@Model.Count</span> active candidates
        </div>
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link rounded-start-3 px-3" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)">
                        <i class="bi bi-chevron-left me-1"></i> Previous
                    </a>
                </li>
                <li class="page-item active"><a class="page-link px-3">@Model.PageIndex</a></li>
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link rounded-end-3 px-3" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)">
                        Next <i class="bi bi-chevron-right ms-1"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<style>
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8f9fa; }
    .bg-soft-purple { background-color: #f3f0ff; }
    .text-purple { color: #5541D7; }
</style>

@section Scripts {
    <script>
        function toggleStatus(id) {
            $.post('/Candidate/ToggleStatus/' + id, function(res) {
                if (res.success) {
                    Swal.fire({
                        title: 'Updated!',
                        text: res.message || 'Candidate status has been toggled.',
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => location.reload());
                } else {
                    Swal.fire('Error', res.message || 'Failed to update candidate status.', 'error');
                }
            });
        }

        function deleteCandidate(id) {
            Swal.fire({
                title: 'Delete Candidate?',
                text: "This will permanently remove the candidate from the system.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6e7881',
                confirmButtonText: 'Yes, delete!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Candidate/Delete/' + id, function(res) {
                        if (res.success) {
                            Swal.fire({
                                title: 'Deleted!',
                                text: res.message || 'Candidate record removed.',
                                icon: 'success',
                                timer: 1500,
                                showConfirmButton: false
                            }).then(() => location.reload());
                        } else {
                            Swal.fire('Failed!', res.message || 'Could not delete candidate.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
