@model RecruitmentsystemMVC.Models.DTOs.UserDTO
@{
    ViewData["Title"] = "Candidate Profile Details";
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="card p-0 shadow-sm border-0 rounded-4 overflow-hidden">
            <!-- Header Section -->
            <div class="bg-primary p-4 text-white">
                <div class="d-flex align-items-center">
                    <div class="avatar-xl bg-white text-primary rounded-circle d-flex align-items-center justify-content-center me-4" style="width: 80px; height: 80px; font-size: 2rem; font-weight: 700;">
                        @((Model.FullName?.Length >= 2) ? Model.FullName.Substring(0, 2).ToUpper() : "CA")
                    </div>
                    <div>
                        <h3 class="fw-bold mb-1">@Model.FullName</h3>
                        <p class="mb-0 opacity-75"><i class="bi bi-envelope me-2"></i>@Model.Email</p>
                    </div>
                </div>
            </div>

            <!-- Content Section -->
            <div class="p-4">
                <div class="row g-4">
                    <div class="col-md-7">
                        <h5 class="fw-bold mb-3">Contact Information</h5>
                        <div class="list-group list-group-flush">
                            <div class="list-group-item px-0 border-0 d-flex justify-content-between">
                                <span class="text-muted">Full Name</span>
                                <span class="fw-medium">@Model.FullName</span>
                            </div>
                            <div class="list-group-item px-0 border-0 d-flex justify-content-between">
                                <span class="text-muted">Primary Email</span>
                                <span class="fw-medium">@Model.Email</span>
                            </div>
                            <div class="list-group-item px-0 border-0 d-flex justify-content-between">
                                <span class="text-muted">Phone Number</span>
                                <span class="fw-medium">@Model.Phone</span>
                            </div>

                        </div>
                    </div>
                    <div class="col-md-5 border-start ps-md-4">
                        <h5 class="fw-bold mb-3">Documents & Resume</h5>
                        <div class="card bg-light border-0 p-3 rounded-4 mb-3">
                             <div class="d-flex align-items-center">
                                 <i class="bi bi-file-earmark-pdf fs-2 text-danger me-3"></i>
                                 <div>
                                     <h6 class="mb-0 fw-bold">Curriculum Vitae</h6>
                                     <small class="text-muted">Uploaded 2 days ago</small>
                                 </div>
                             </div>
                             <button class="btn btn-primary btn-sm w-100 mt-3 rounded-3">Download Resume</button>
                        </div>
                    </div>
                </div>

                <hr class="my-4 opacity-50">

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn btn-link text-muted p-0 text-decoration-none"><i class="bi bi-arrow-left me-1"></i> Back to Talent Pool</a>
                    <div class="d-flex gap-2">

                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4 rounded-3">Edit Candidate</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleStatus(id) {
            $.post('/Candidate/ToggleStatus/' + id, function(res) {
                if (res.success) location.reload();
                else Swal.fire('Error', 'Failed to update status', 'error');
            });
        }
    </script>
}
