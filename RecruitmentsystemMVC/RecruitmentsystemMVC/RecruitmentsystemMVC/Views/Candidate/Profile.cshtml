@model RecruitmentsystemMVC.Models.DTOs.UserDTO
@{
    ViewData["Title"] = "My Profile";
}

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 rounded-3 text-center p-4">
            <div class="mb-3">
                <img src="https://ui-avatars.com/api/?name=@Model.FullName&background=random&size=128" class="rounded-circle shadow-sm" />
            </div>
            <h4 class="fw-bold mb-1">@Model.FullName</h4>
            <p class="text-muted small mb-3">@Model.Email</p>
            <span class="badge bg-primary bg-opacity-10 text-primary mb-4 p-2 px-3 rounded-pill">@Model.Role</span>
            
            <!-- Resume upload removed -->
        </div>
    </div>
    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-3 p-4">
            <h5 class="fw-bold mb-4"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Personal Information</h5>
            <div class="row g-4">
                <div class="col-md-6">
                    <label class="form-label text-muted small fw-bold">Full Name</label>
                    <p class="mb-0 fw-medium">@Model.FullName</p>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small fw-bold">Email Address</label>
                    <p class="mb-0 fw-medium">@Model.Email</p>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small fw-bold">Phone Number</label>
                    <p class="mb-0 fw-medium">@Model.Phone</p>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small fw-bold">Account Status</label>
                    <p class="mb-0">
                        @if (Model.IsActive)
                        {
                            <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Active</span>
                        }
                        else
                        {
                            <span class="text-danger"><i class="bi bi-x-circle-fill me-1"></i>Inactive</span>
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Scripts related to resume upload have been removed -->
}
