@model RecruitmentsystemMVC.Models.DTOs.LoginDTO
@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - GoHire</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body, html {
            height: 100%;
            font-family: 'Inter', sans-serif;
        }
        .brand-section {
            background-color: #6842ED;
            position: relative;
            overflow: hidden;
        }
        .brand-circle-1 {
            position: absolute;
            top: -150px;
            right: -100px;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.04);
            z-index: 0;
        }
        .brand-circle-2 {
            position: absolute;
            bottom: -150px;
            left: -150px;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.06);
            z-index: 0;
        }
        .brand-content {
            z-index: 1;
        }
        .icon-box {
            background: rgba(255, 255, 255, 0.2);
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
        }
        .logo-box {
            background: rgba(255, 255, 255, 0.2);
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
        }
        .form-control, .input-group-text {
            background-color: #F1F4F9;
            border: none;
        }
        .form-control:focus {
            background-color: #F1F4F9;
            box-shadow: none;
            border: 1px solid #6842ED;
        }
        .input-group:focus-within .input-group-text,
        .input-group:focus-within .form-control {
            border-top: 1px solid #6842ED;
            border-bottom: 1px solid #6842ED;
        }
        .input-group:focus-within .input-group-text {
            border-left: 1px solid #6842ED;
        }
        .input-group:focus-within .form-control {
            border-right: 1px solid #6842ED;
        }
        .btn-primary-custom {
            background-color: #5541D7;
            border-color: #5541D7;
            color: white;
            padding: 12px;
            font-weight: 600;
        }
        .btn-primary-custom:hover {
            background-color: #4936B9;
            color: white;
        }
        .feature-text {
            color: rgba(255, 255, 255, 0.9);
            font-size: 0.95rem;
        }
        .subtitle-text {
            color: rgba(255, 255, 255, 0.85);
            font-size: 1.1rem;
        }
    </style>
</head>
<body>
    <div class="container-fluid h-100 p-0">
        <div class="row h-100 g-0">
            <!-- Left Side: Branding -->
            <div class="col-md-7 brand-section d-none d-md-flex flex-column justify-content-center align-items-center text-white p-5">
                <div class="brand-circle-1"></div>
                <div class="brand-circle-2"></div>
                
                <div class="brand-content text-center" style="max-width: 520px;">
                    <div class="mb-5 d-flex align-items-center justify-content-center gap-3">
                        <div class="logo-box">
                            <span class="fs-4 fw-bold">G</span>
                        </div>
                        <h2 class="m-0 fw-bold fs-2">GoHire</h2>
                    </div>
                    
                    <h1 class="fw-bold mb-3" style="font-size: 2.5rem; line-height: 1.2;">Your recruitment journey<br>starts here</h1>
                    <p class="subtitle-text mb-5">Connect top talent with great opportunities. Streamline your hiring process from application to offer.</p>
                    
                    <div class="d-flex flex-column gap-4 text-start mx-auto" style="max-width: 400px;">
                        <div class="d-flex align-items-center gap-3">
                            <div class="icon-box">
                                <i class="bi bi-people-fill text-white fs-5"></i>
                            </div>
                            <span class="feature-text">Manage candidates and track applications</span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="icon-box">
                                <i class="bi bi-calendar-event-fill text-white fs-5"></i>
                            </div>
                            <span class="feature-text">Schedule and conduct interviews seamlessly</span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="icon-box">
                                <i class="bi bi-graph-up-arrow text-white fs-5"></i>
                            </div>
                            <span class="feature-text">Real-time analytics and hiring insights</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Right Side: Login Form -->
            <div class="col-md-5 d-flex flex-column justify-content-center bg-white p-5">
                <div class="mx-auto w-100" style="max-width: 400px;">
                    <h2 class="fw-bold mb-1" style="color: #111827;">Welcome back</h2>
                    <p class="text-muted mb-4 pb-2">Sign in to your GoHire account</p>
                    
                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        
                        <div class="mb-4">
                            <label class="form-label fw-semibold text-dark small mb-2">Email address</label>
                            <div class="input-group">
                                <span class="input-group-text px-3"><i class="bi bi-envelope text-muted"></i></span>
                                <input asp-for="Email" type="email" class="form-control ps-0 py-2 fs-6" placeholder="admin@company.com" required>
                            </div>
                        </div>
                        
                        <div class="mb-5">
                            <label class="form-label fw-semibold text-dark small mb-2">Password</label>
                            <div class="input-group">
                                <span class="input-group-text px-3"><i class="bi bi-lock text-muted"></i></span>
                                <input asp-for="Password" type="password" class="form-control ps-0 py-2 fs-6" placeholder="••••••••" required>
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-primary-custom w-100 rounded-3 d-flex justify-content-center align-items-center gap-2 mb-4">
                            Sign In <i class="bi bi-arrow-right"></i>
                        </button>
                        
                        <div class="d-flex align-items-center mb-4">
                            <hr class="flex-grow-1" style="opacity: 0.15;">
                            <span class="px-3 text-muted small">or</span>
                            <hr class="flex-grow-1" style="opacity: 0.15;">
                        </div>
                        
                        <div class="text-center">
                            <p class="text-muted small">Don't have an account? <a asp-action="Register" class="text-decoration-none fw-semibold" style="color: #5541D7;">Register as Candidate</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
