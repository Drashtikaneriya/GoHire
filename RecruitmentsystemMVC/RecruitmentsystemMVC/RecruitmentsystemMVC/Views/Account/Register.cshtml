@model RecruitmentsystemMVC.Models.DTOs.RegisterDTO
@{
    Layout = null;
    ViewData["Title"] = "Register";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account - GoHire</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body, html {
            height: 100%;
            font-family: 'Inter', sans-serif;
            background-color: #f4f6fb;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .register-container {
            width: 100%;
            max-width: 480px;
            padding: 1rem;
        }
        .register-card {
            background-color: #ffffff;
            border-radius: 1.25rem;
            padding: 3rem 2.5rem;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03);
            border: 1px solid #f1f5f9;
        }
        .logo-box {
            background-color: #5541D7;
            width: 42px;
            height: 42px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            color: white;
            font-weight: 700;
            font-size: 1.25rem;
        }
        .brand-text {
            font-size: 1.5rem;
            font-weight: 700;
            color: #111827;
        }
        .brand-text-highlight {
            color: #5541D7;
        }
        
        .form-label {
            font-size: 0.875rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 0.5rem;
        }
        
        .custom-input-group {
            display: flex;
            align-items: center;
            border: 1px solid #d1d5db;
            border-radius: 0.6rem;
            background-color: #ffffff;
            transition: all 0.2s;
            overflow: hidden;
        }
        .custom-input-group.bg-lightblue {
            background-color: #eff4ff;
            border-color: #e4ebf7;
        }
        .custom-input-group:focus-within {
            border-color: #5541D7;
            box-shadow: 0 0 0 3px rgba(85, 65, 215, 0.1);
        }
        
        .custom-icon {
            padding: 0.6rem 0.25rem 0.6rem 0.75rem;
            color: #9ca3af;
            display: flex;
            align-items: center;
        }
        .custom-input {
            flex: 1 1 auto;
            border: none;
            background: transparent;
            padding: 0.6rem 0.75rem 0.6rem 0.25rem;
            color: #111827;
            outline: none;
        }
        .custom-input::placeholder {
            color: #6b7280;
        }
        
        .btn-primary-custom {
            background-color: #5541D7;
            border-color: #5541D7;
            color: white;
            padding: 0.75rem;
            font-weight: 600;
            border-radius: 0.6rem;
            font-size: 1rem;
        }
        .btn-primary-custom:hover {
            background-color: #4936B9;
            color: white;
        }
        .text-subtitle {
            color: #6b7280;
            font-size: 0.95rem;
        }
        .link-primary {
            color: #5541D7;
            text-decoration: none;
            font-weight: 600;
        }
        .link-primary:hover {
            text-decoration: underline;
        }
        .optional-text {
            color: #9ca3af;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <div class="register-container">
        <div class="register-card">
            <div class="d-flex align-items-center justify-content-center gap-2 mb-4">
                <div class="logo-box">G</div>
                <div class="brand-text">Go<span class="brand-text-highlight">Hire</span></div>
            </div>
            
            <div class="text-center mb-4 pb-2">
                <h2 class="fw-bold fs-3 mb-2" style="color: #111827;">Create your account</h2>
                <p class="text-subtitle">Join GoHire as a Candidate &mdash; it's free</p>
            </div>
            
            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                
                <div class="mb-4">
                    <label class="form-label">Full Name</label>
                    <div class="custom-input-group">
                        <div class="custom-icon"><i class="bi bi-person"></i></div>
                        <input asp-for="FullName" class="custom-input" placeholder="John Doe" required />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Email</label>
                    <div class="custom-input-group bg-lightblue">
                        <div class="custom-icon"><i class="bi bi-envelope"></i></div>
                        <input asp-for="Email" type="email" class="custom-input" placeholder="admin@company.com" required />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-4 pb-2">
                    <div class="col-6">
                        <label class="form-label">Password</label>
                        <div class="custom-input-group bg-lightblue">
                            <div class="custom-icon"><i class="bi bi-lock"></i></div>
                            <input asp-for="Password" type="password" class="custom-input" placeholder="••••••••" required />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="col-6">
                        <label class="form-label">Phone <span class="optional-text">(optional)</span></label>
                        <div class="custom-input-group">
                            <div class="custom-icon"><i class="bi bi-phone"></i></div>
                            <input asp-for="Phone" class="custom-input" placeholder="+91 ..." />
                        </div>
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                </div>
                
                <button type="submit" class="btn btn-primary-custom w-100 d-flex justify-content-center align-items-center gap-2 mb-4">
                    Create Account <i class="bi bi-arrow-right"></i>
                </button>
                
                <div class="text-center">
                    <p class="text-muted small mb-0" style="font-size: 0.95rem;">Already have an account? <a asp-action="Login" class="link-primary">Sign in</a></p>
                </div>
            </form>
        </div>
    </div>
    
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
