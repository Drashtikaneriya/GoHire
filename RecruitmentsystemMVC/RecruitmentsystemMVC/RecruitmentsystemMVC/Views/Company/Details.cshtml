@model RecruitmentsystemMVC.Models.DTOs.CompanyDTO
@{
    ViewData["Title"] = "Company Details";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card p-4 shadow-sm border-0 rounded-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="d-flex align-items-center">
                    <div class="avatar-lg bg-light text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 64px; height: 64px; font-size: 1.5rem; font-weight: 700;">
                        @Model.CompanyName?.Substring(0, 1).ToUpper()
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0">@Model.CompanyName</h3>
                        <span class="text-muted">@Model.Industry</span>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.CompanyId" class="btn btn-sm btn-outline-primary px-3 rounded-pill">Edit Details</a>
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill small">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-2 rounded-pill small">Inactive</span>
                    }
                </div>
            </div>

            <div class="row g-4 mt-2">
                <div class="col-md-6">
                    <div class="mb-4">
                        <label class="text-muted small d-block mb-1">Email Address</label>
                        <span class="fw-medium">@Model.Email</span>
                    </div>
                    <div class="mb-4">
                        <label class="text-muted small d-block mb-1">Phone Number</label>
                        <span class="fw-medium">@Model.Phone</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-4">
                        <label class="text-muted small d-block mb-1">Official Website</label>
                        <a href="@Model.Website" target="_blank" class="text-primary fw-medium text-decoration-none">@Model.Website</a>
                    </div>
                    <div class="mb-4">
                        <label class="text-muted small d-block mb-1">Headquarters</label>
                        <span class="fw-medium">@Model.Address</span>
                    </div>
                </div>
            </div>

            <hr class="my-4 opacity-50">
            
            <div class="d-flex justify-content-between align-items-center">
                <a asp-action="Index" class="btn btn-link text-decoration-none text-muted p-0"><i class="bi bi-arrow-left me-1"></i> Back to Directory</a>
                <button class="btn btn-danger btn-sm px-4 rounded-3" onclick="deleteCompany(@Model.CompanyId)">Delete Company</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteCompany(id) {
            Swal.fire({
                title: 'Are you sure?',
                text: "Deleting this company might affect active job postings!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Yes, delete!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Company/Delete/' + id, function(res) {
                        if (res.success) window.location.href = '/Company';
                        else Swal.fire('Error', res.message, 'error');
                    });
                }
            });
        }
    </script>
}
