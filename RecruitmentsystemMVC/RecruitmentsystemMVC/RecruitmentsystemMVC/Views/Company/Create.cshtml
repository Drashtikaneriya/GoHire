@model RecruitmentsystemMVC.Models.DTOs.CreateCompanyDTO
@{
    ViewData["Title"] = "Create Company";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card p-4 shadow-sm border-0 rounded-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold mb-0">Register New Company</h4>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-2"></i> Back to List
                </a>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mb-4">
                    <div asp-validation-summary="All" class="text-danger small mb-0"></div>
                </div>
            }

            <form asp-action="Create" method="post">
                <div class="row g-3">
                    <div class="col-md-6 mb-3">
                        <label asp-for="CompanyName" class="form-label fw-medium text-dark small mb-2">Company Name <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-building text-muted"></i></span>
                            <input asp-for="CompanyName" class="form-control bg-light border-start-0 ps-0" placeholder="Google, Microsoft, etc." required />
                        </div>
                        <span asp-validation-for="CompanyName" class="text-danger small mt-1"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Industry" class="form-label fw-medium text-dark small mb-2">Industry</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-briefcase text-muted"></i></span>
                            <input asp-for="Industry" class="form-control bg-light border-start-0 ps-0" placeholder="Technology, Finance, etc." />
                        </div>
                        <span asp-validation-for="Industry" class="text-danger small mt-1"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label fw-medium text-dark small mb-2">Corporate Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                            <input asp-for="Email" type="email" class="form-control bg-light border-start-0 ps-0" placeholder="contact@company.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small mt-1"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label fw-medium text-dark small mb-2">Phone Number</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-telephone text-muted"></i></span>
                            <input asp-for="Phone" class="form-control bg-light border-start-0 ps-0" placeholder="+1 800 123 4567" />
                        </div>
                        <span asp-validation-for="Phone" class="text-danger small mt-1"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Website" class="form-label fw-medium text-dark small mb-2">Website URL</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-globe text-muted"></i></span>
                            <input asp-for="Website" type="url" class="form-control bg-light border-start-0 ps-0" placeholder="https://www.company.com" />
                        </div>
                        <span asp-validation-for="Website" class="text-danger small mt-1"></span>
                    </div>

                    <div class="col-md-12 mb-4">
                        <label asp-for="Address" class="form-label fw-medium text-dark small mb-2">Location/Address <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-geo-alt text-muted"></i></span>
                            <input asp-for="Address" class="form-control bg-light border-start-0 ps-0" placeholder="City, State, Country" required />
                        </div>
                        <span asp-validation-for="Address" class="text-danger small mt-1"></span>
                    </div>
                </div>

                <div class="border-top pt-4 d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save me-2"></i> Save Company
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
