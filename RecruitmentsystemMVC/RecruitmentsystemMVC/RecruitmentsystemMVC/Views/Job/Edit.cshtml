@model RecruitmentsystemMVC.Models.DTOs.JobDTO
@{
    ViewData["Title"] = "Update Job Position";
}

<div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">
        <div class="card shadow-sm border-0 rounded-4 p-4">
            <div class="d-flex align-items-center mb-4">
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-circle me-3" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h4 class="fw-bold mb-0">Edit Job: @Model.Title</h4>
            </div>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-8">
                        <label asp-for="Title" class="form-label fw-semibold">Job Title</label>
                        <input asp-for="Title" class="form-control" placeholder="e.g. Senior Software Engineer" required>
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="EmploymentType" class="form-label fw-semibold">Employment Type</label>
                        <select asp-for="EmploymentType" class="form-select">
                            <option value="Full-time">Full-time</option>
                            <option value="Part-time">Part-time</option>
                            <option value="Contract">Contract</option>
                            <option value="Remote">Remote</option>
                            <option value="Freelance">Freelance</option>
                        </select>
                        <span asp-validation-for="EmploymentType" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CompanyId" class="form-label fw-semibold">Partner Company</label>
                        <select asp-for="CompanyId" class="form-select" required>
                            <option value="">Select Company</option>
                            @foreach (var company in (List<RecruitmentsystemMVC.Models.DTOs.CompanyDTO>)ViewBag.Companies)
                            {
                                <option value="@company.CompanyId">@company.CompanyName</option>
                            }
                        </select>
                        <span asp-validation-for="CompanyId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Location" class="form-label fw-semibold">Work Location</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-geo-alt"></i></span>
                            <input asp-for="Location" class="form-control border-start-0" placeholder="e.g. New York, NY">
                        </div>
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>

                    <input type="hidden" asp-for="Status" />

                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-semibold">Job Description</label>
                        <textarea asp-for="Description" class="form-control" rows="5">@Model.Description</textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="SalaryMin" class="form-label fw-semibold">Min Salary</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="SalaryMin" type="number" step="0.01" class="form-control">
                        </div>
                        <span asp-validation-for="SalaryMin" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="SalaryMax" class="form-label fw-semibold">Max Salary</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="SalaryMax" type="number" step="0.01" class="form-control">
                        </div>
                        <span asp-validation-for="SalaryMax" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="ClosingDate" class="form-label fw-semibold">Closing Date</label>
                        <input asp-for="ClosingDate" type="datetime-local" class="form-control" value="@Model.ClosingDate?.ToString("yyyy-MM-ddTHH:mm")">
                        <span asp-validation-for="ClosingDate" class="text-danger small"></span>
                    </div>

                    <input type="hidden" asp-for="CreatedByUserId" />
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Update Position</button>
                </div>
            </form>
        </div>
    </div>
</div>
