@model RecruitmentsystemMVC.Models.PaginatedList<RecruitmentsystemMVC.Models.DTOs.JobDTO>
@{
    ViewData["Title"] = "Job Positions";
}

<div class="card p-4 shadow-sm border-0 rounded-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Employment Opportunities</h4>
            <p class="text-muted small mb-0">Manage and track all current job openings</p>
        </div>
        <a asp-action="Create" class="btn btn-primary d-flex align-items-center px-3 py-2 rounded-3">
            <i class="bi bi-plus-circle me-2"></i> Post New Job
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover w-100 align-middle">
            <thead class="bg-light">
                <tr>
                    <th class="ps-3 border-0 py-3 text-uppercase small fw-bold text-muted">Job Details</th>
                    <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Company</th>
                    <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Location</th>
                    <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Type</th>
                    <th class="border-0 py-3 text-uppercase small fw-bold text-muted">Salary Range</th>
                    <th class="text-end pe-3 border-0 py-3 text-uppercase small fw-bold text-muted">Actions</th>
                </tr>
            </thead>
            <tbody class="border-top-0">
                @foreach (var job in Model)
                {
                    <tr>
                        <td class="ps-3">
                            <div>
                                <span class="fw-bold text-primary d-block">@job.Title</span>
                                <small class="text-muted">ID: #@job.Id</small>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="avatar-xs me-2 bg-light text-muted rounded p-1 d-flex align-items-center justify-content-center" style="width: 24px; height: 24px;">
                                    <i class="bi bi-building small"></i>
                                </div>
                                <span class="small fw-medium">@job.CompanyName</span>
                            </div>
                        </td>
                        <td class="small"><i class="bi bi-geo-alt me-1 text-muted"></i> @job.Location</td>
                        <td>
                            <span class="badge rounded-pill bg-light text-dark border px-3">@job.EmploymentType</span>
                        </td>
                        <td class="small fw-medium text-success">
                            $@job.SalaryMin.ToString("N0") - $@job.SalaryMax.ToString("N0")
                        </td>
                        <td class="text-end pe-3">
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn btn-sm btn-white border shadow-sm text-danger" onclick="deleteJob(@job.Id)" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <div class="text-muted small">
            Showing <span class="fw-bold">@Model.Count</span> active job postings
        </div>
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link rounded-start-3 px-3" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)">
                        <i class="bi bi-chevron-left me-1"></i> Previous
                    </a>
                </li>
                <li class="page-item active"><a class="page-link px-3">@Model.PageIndex</a></li>
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link rounded-end-3 px-3" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)">
                        Next <i class="bi bi-chevron-right ms-1"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<style>
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8f9fa; }
    .avatar-xs { font-size: 0.8rem; }
</style>

@section Scripts {
    <script>
        function toggleJobStatus(id) {
            $.post('/Job/ToggleStatus/' + id, function(res) {
                if (res.success) {
                    Swal.fire({
                        title: 'Updated!',
                        text: res.message || 'Job status has been toggled.',
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => location.reload());
                } else {
                    Swal.fire('Error', res.message || 'Failed to update job status.', 'error');
                }
            });
        }

        function deleteJob(id) {
            Swal.fire({
                title: 'Remove Job Posting?',
                text: "This action will archive the job. Associated applications will remain.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6e7881',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Job/Delete/' + id, function(res) {
                        if (res.success) {
                            Swal.fire({
                                title: 'Deleted!',
                                text: res.message || 'Job posting has been removed.',
                                icon: 'success',
                                timer: 1500,
                                showConfirmButton: false
                            }).then(() => location.reload());
                        } else {
                            Swal.fire('Failed!', res.message || 'Could not delete job position.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
