@inject RecruitmentsystemMVC.Helpers.RoleHelper RoleHelper
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GoHire</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div id="loader-wrapper">
        <div class="spinner"></div>
    </div>
    <style>
        body, html { height: 100vh; overflow: hidden; font-family: 'Inter', sans-serif; }
        .sidebar { background-color: #fff !important; width: 260px !important; min-width: 260px !important; }
        .sidebar .nav-link { color: #475569 !important; padding: 0.75rem 1rem; border-radius: 0.5rem; transition: all 0.2s; font-size: 0.9rem; font-weight: 500; margin-bottom: 2px; }
        .sidebar .nav-link:hover { background-color: #f1f5f9 !important; color: #5541D7 !important; }
        .sidebar .nav-link.active { background-color: #5541D7 !important; color: #fff !important; box-shadow: 0 4px 6px -1px rgba(85, 65, 215, 0.3); }
        .sidebar-section { font-size: 0.7rem; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; margin-top: 1.5rem; padding-left: 0.5rem; }
        .brand-logo-box { width: 36px; height: 36px; background-color: #5541D7; border-radius: 10px; color: white; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.3rem; }
        .main-content { background-color: #f8fafc; }
        .navbar { background-color: #fff !important; border-bottom: 1px solid #e2e8f0; }
        .hide-caret::after { display: none !important; }
        .dropdown-item:active { background-color: #5541D7 !important; }
    </style>
    <div class="container-fluid p-0">
        <div class="row g-0 flex-nowrap">
            <!-- Sidebar -->
            <div class="col-auto col-md-3 col-xl-2 px-sm-2 px-0 sidebar border-end d-flex flex-column align-items-center align-items-sm-start px-3 pt-2 min-vh-100 shadow-sm" style="width: 260px; z-index: 1000;">
                <a href="/" class="d-flex align-items-center pb-3 mb-md-0 me-md-auto text-decoration-none pt-3 w-100 ps-2">
                    <div class="brand-logo-box me-2">G</div>
                    <span class="fs-5 d-none d-sm-inline fw-bold text-dark">GoHire</span>
                </a>
                
                <div class="w-100 px-2 mt-3 flex-grow-1 overflow-auto" style="height: calc(100vh - 180px);">
                    <ul class="nav nav-pills flex-column mb-sm-auto mb-0 align-items-center align-items-sm-start w-100" id="menu">
                        <div class="sidebar-section w-100">MAIN</div>
                        <li class="nav-item w-100 mb-1">
                            <a asp-controller="Dashboard" asp-action="Index" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                                <i class="bi bi-grid me-2"></i> <span class="d-none d-sm-inline">Dashboard</span>
                            </a>
                        </li>
                        
                        @if (RoleHelper.IsAdmin())
                        {
                            <div class="sidebar-section w-100">MANAGEMENT</div>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="User" asp-action="Index" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "User" ? "active" : "")">
                                    <i class="bi bi-people me-2"></i> <span class="d-none d-sm-inline">Users</span> 
                                </a>
                            </li>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="Role" asp-action="Index" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Role" ? "active" : "")">
                                    <i class="bi bi-shield-lock me-2"></i> <span class="d-none d-sm-inline">Roles</span> 
                                </a>
                            </li>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="InterviewRound" asp-action="Index" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "InterviewRound" ? "active" : "")">
                                    <i class="bi bi-list-ol me-2"></i> <span class="d-none d-sm-inline">Interview Rounds</span> 
                                </a>
                            </li>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="Company" asp-action="Index" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Company" ? "active" : "")">
                                    <i class="bi bi-building me-2"></i> <span class="d-none d-sm-inline">Companies</span> 
                                </a>
                            </li>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="Job" asp-action="Index" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Job" ? "active" : "")">
                                    <i class="bi bi-briefcase me-2"></i> <span class="d-none d-sm-inline">Job Positions</span> 
                                </a>
                            </li>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="Application" asp-action="Index" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Application" ? "active" : "")">
                                    <i class="bi bi-file-earmark-text me-2"></i> <span class="d-none d-sm-inline">Applications</span> 
                                </a>
                            </li>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="Candidate" asp-action="Index" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Candidate" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                                    <i class="bi bi-person-badge me-2"></i> <span class="d-none d-sm-inline">Candidates</span> 
                                </a>
                            </li>

                            <div class="sidebar-section w-100">RECRUITMENT</div>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="Interview" asp-action="Index" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Interview" ? "active" : "")">
                                    <i class="bi bi-calendar-event me-2"></i> <span class="d-none d-sm-inline">Interviews</span> 
                                </a>
                            </li>
                        }
                        else if (RoleHelper.IsHR())
                        {
                            <div class="sidebar-section w-100">MANAGEMENT</div>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="Job" asp-action="Index" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Job" ? "active" : "")">
                                    <i class="bi bi-briefcase me-2"></i> <span class="d-none d-sm-inline">Job Postings</span> 
                                </a>
                            </li>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="Application" asp-action="Index" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Application" ? "active" : "")">
                                    <i class="bi bi-file-earmark-person me-2"></i> <span class="d-none d-sm-inline">Applications</span> 
                                </a>
                            </li>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="InterviewRound" asp-action="Index" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "InterviewRound" ? "active" : "")">
                                    <i class="bi bi-list-ol me-2"></i> <span class="d-none d-sm-inline">Rounds (View Only)</span> 
                                </a>
                            </li>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="Interview" asp-action="Index" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Interview" ? "active" : "")">
                                    <i class="bi bi-calendar-event me-2"></i> <span class="d-none d-sm-inline">Interviews</span> 
                                </a>
                            </li>
                        }
                        else if (RoleHelper.IsInterviewer())
                        {
                            <div class="sidebar-section w-100">INTERVIEWS</div>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="Interview" asp-action="Index" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Interview" ? "active" : "")">
                                    <i class="bi bi-calendar-check me-2"></i> <span class="d-none d-sm-inline">My Interviews</span> 
                                </a>
                            </li>
                        }
                        else if (RoleHelper.IsCandidate())
                        {
                            <div class="sidebar-section w-100">CANDIDATE</div>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="Job" asp-action="Browse" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Job" ? "active" : "")">
                                    <i class="bi bi-search me-2"></i> <span class="d-none d-sm-inline">Browse Jobs</span> 
                                </a>
                            </li>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="Application" asp-action="MyApplications" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Application" && ViewContext.RouteData.Values["Action"]?.ToString() == "MyApplications" ? "active" : "")">
                                    <i class="bi bi-journal-text me-2"></i> <span class="d-none d-sm-inline">My Applications</span> 
                                </a>
                            </li>
                            <li class="nav-item w-100 mb-1">
                                <a asp-controller="Interview" asp-action="MyInterviews" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Interview" && ViewContext.RouteData.Values["Action"]?.ToString() == "MyInterviews" ? "active" : "")">
                                    <i class="bi bi-calendar-check me-2"></i> <span class="d-none d-sm-inline">My Interviews</span> 
                                </a>
                            </li>
                            @* <li class="nav-item w-100 mb-1">
                                <a asp-controller="Candidate" asp-action="Profile" class="nav-link w-100 d-flex align-items-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Candidate" ? "active" : "")">
                                    <i class="bi bi-person-circle me-2"></i> <span class="d-none d-sm-inline">My Profile</span> 
                                </a>
                            </li> *@
                        }
                    </ul>
                </div>
                
                <div class="w-100 border-top pt-3 pb-3 mt-auto">
                    <div class="ps-3 small text-muted">
                        &copy; 2024 GoHire
                    </div>
                </div>
            </div>

            <!-- Content -->
            <div class="col px-4 main-content vh-100 overflow-auto d-flex flex-column pb-4">
                <nav class="navbar navbar-expand-lg bg-white border-bottom px-4 py-2 mb-4">
                    <div class="container-fluid p-0">
                        <div>
                            <span class="navbar-brand mb-0 fw-bold fs-5 text-dark">@ViewData["Title"]</span>
                        </div>
                        
                        <div class="d-flex align-items-center ms-auto">
                            <div class="dropdown">
                                <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle hide-caret" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="me-2 text-end d-none d-sm-block">
                                        <div class="fw-bold text-dark small" style="line-height: 1.2;">@(Context.Session.GetString("UserName") ?? "Admin")</div>
                                        <div class="text-muted" style="font-size: 0.75rem;">@(Context.Session.GetString("UserRole") ?? "Administrator")</div>
                                    </div>
                                    @{
                                        var nameTop = Context.Session.GetString("UserName") ?? "U";
                                        var initTop = nameTop.Length >= 2 ? nameTop.Substring(0,2).ToUpper() : nameTop.ToUpper();
                                    }
                                    <div class="rounded-circle text-white d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 38px; height: 38px; font-size: 0.9rem; background-color: #5541D7;">
                                        @initTop
                                    </div>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2" aria-labelledby="userDropdown">
                                    <li><h6 class="dropdown-header">Manage Account</h6></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Candidate" asp-action="Profile"><i class="bi bi-person me-2"></i> Profile</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item py-2 text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i> Sign Out</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </nav>

                <div class="container-fluid">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ajaxStart(function() {
            $("#loader-wrapper").css("display", "flex");
        }).ajaxStop(function() {
            $("#loader-wrapper").hide();
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
