@model List<RecruitmentsystemMVC.Models.DTOs.InterviewResponseDTO>

@{
    ViewData["Title"] = "Interviews (Admin)";
}

<div class="container py-5">
    <div class="row mb-5 align-items-center">
        <div class="col-md-6">
            <h1 class="fw-bold text-dark display-6 mb-1">Interviews</h1>
            <p class="text-muted mb-0">Overview of all scheduled interviews (Read-only)</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light border-bottom-0">
                    <tr class="text-secondary small text-uppercase">
                        <th class="ps-4">ID</th>
                        <th>Candidate</th>
                        <th>Job Title</th>
                        <th>Date & Time</th>
                        <th>Mode / Round</th>
                        <th>Result</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var interview in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-muted">#@interview.InterviewId</td>
                            <td><div class="fw-bold text-dark">@interview.CandidateName</div></td>
                            <td><span class="badge bg-light text-dark border fw-normal">@interview.JobTitle</span></td>
                            <td class="small">
                                <div class="fw-bold"><i class="bi bi-calendar3 me-1"></i> @interview.InterviewDate.ToString("MMM dd, yyyy")</div>
                                <div class="text-muted">@interview.InterviewDate.ToString("hh:mm tt")</div>
                            </td>
                            <td>
                                <span class="badge bg-info-subtle text-info rounded-pill px-3">@interview.Mode</span>
                                <div class="small text-muted mt-1 ps-1">Round @interview.RoundNo</div>
                            </td>
                            <td>
                                @{
                                    var resColor = "secondary";
                                    if (interview.Result == "Passed") resColor = "success";
                                    else if (interview.Result == "Failed") resColor = "danger";
                                    else if (interview.Result == "Pending") resColor = "warning";
                                }
                                <span class="badge bg-@resColor rounded-pill px-3">@interview.Result</span>
                            </td>
                            <td class="text-end pe-4">
                                <button onclick="ViewInterview(@interview.InterviewId)" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                    <i class="bi bi-eye"></i> View
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">No interviews scheduled yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="interviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Interview Assessment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 pt-2">
                <div id="interviewBody"></div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    function ViewInterview(id) {
        const body = document.getElementById('interviewBody');
        body.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary"></div></div>';
        const modal = new bootstrap.Modal(document.getElementById('interviewModal'));
        modal.show();

        fetch(`/Admin/Interviews/GetDetails/${id}`)
            .then(r => r.json())
            .then(data => {
                const i = data.data;
                body.innerHTML = `
                    <div class="p-3 bg-light rounded-4 mb-4 border border-info">
                        <div class="row align-items-center">
                            <div class="col-md-2 p-3 text-center d-none d-md-block">
                                <i class="bi bi-person-video3 fs-1 text-info"></i>
                            </div>
                            <div class="col-md-10">
                                <div class="fw-bold mb-0 text-dark fs-5">${i.candidateName}</div>
                                <div class="text-muted fw-bold small text-uppercase">${i.jobTitle}</div>
                            </div>
                        </div>
                    </div>
                    <div class="px-2">
                        <label class="small text-muted fw-bold text-uppercase d-block mb-1">Feedback</label>
                        <div class="p-3 bg-white border rounded-3 mb-4 shadow-sm" style="font-size: 0.95rem;">
                            ${i.feedback || "<em>No feedback provided recorded.</em>"}
                        </div>
                        <div class="row mt-4 pt-4 border-top">
                            <div class="col-6">
                                <label class="small text-muted fw-bold text-uppercase d-block mb-1">Status</label>
                                <span class="badge bg-primary fs-6">${i.mode} - R${i.roundNo}</span>
                            </div>
                            <div class="col-6 text-end">
                                <label class="small text-muted fw-bold text-uppercase d-block mb-1">Final Result</label>
                                <span class="badge bg-info fs-6 px-3 py-2">${i.result}</span>
                            </div>
                        </div>
                    </div>
                `;
            });
    }
</script>
