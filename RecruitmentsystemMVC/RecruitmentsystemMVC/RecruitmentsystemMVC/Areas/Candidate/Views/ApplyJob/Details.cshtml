@model RecruitmentsystemMVC.Models.JobApplicationViewModel

@{
    ViewData["Title"] = "Job Details - " + Model.Job.Title;
}

<div class="container py-4">
    <div class="mb-4">
        <a href="/Candidate/ApplyJob" class="text-decoration-none"><i class="bi bi-arrow-left"></i> Back to Jobs</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card p-4 border-0 shadow-sm mb-4">
                <div class="d-flex justify-content-between align-items-start border-bottom pb-4 mb-4">
                    <div>
                        <h2 class="fw-bold mb-2">@Model.Job.Title</h2>
                        <h5 class="text-muted mb-3">@Model.Job.CompanyName</h5>
                        <div class="d-flex gap-2 flex-wrap">
                            <span class="badge bg-light text-dark px-3 py-2 border"><i class="bi bi-geo-alt me-1"></i> @Model.Job.Location</span>
                            <span class="badge bg-light text-dark px-3 py-2 border"><i class="bi bi-briefcase me-1"></i> @Model.Job.Type</span>
                            <span class="badge bg-light text-dark px-3 py-2 border"><i class="bi bi-cash me-1"></i> @Model.Job.SalaryRange</span>
                        </div>
                    </div>
                </div>
                
                <h5 class="fw-bold mb-3">Job Description</h5>
                <div class="text-muted" style="white-space: pre-wrap;">@Model.Job.Description</div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card p-4 border-0 shadow-sm sticky-top" style="top: 100px;">
                <h5 class="fw-bold mb-4">Apply for this position</h5>
                
                <form method="post" action="/Candidate/ApplyJob/Apply" enctype="multipart/form-data">
                    <input type="hidden" name="JobId" value="@Model.JobId" />
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold small text-uppercase">Upload Resume (PDF/DOC)<span class="text-danger">*</span></label>
                        <div class="p-4 border border-2 border-dashed rounded-3 text-center bg-light">
                            <i class="bi bi-cloud-arrow-up display-4 text-muted mb-2"></i>
                            <input type="file" name="Resume" class="form-control mb-2" accept=".pdf,.doc,.docx" required>
                            <small class="text-muted">Max file size: 5MB</small>
                        </div>
                    </div>

                    <div class="alert alert-info py-2 small">
                        <i class="bi bi-info-circle me-1"></i> Your profile details will be shared automatically.
                    </div>

                    <button type="submit" class="btn btn-purple btn-lg w-100 fw-bold shadow-sm">Submit Application</button>
                    <p class="text-center text-muted small mt-3 mb-0">By applying, you agree to our Terms & Conditions.</p>
                </form>
            </div>
        </div>
    </div>
</div>
