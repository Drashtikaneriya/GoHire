@model List<RecruitmentsystemMVC.Models.DTOs.JobPositionDTO>

@{
    ViewData["Title"] = "Apply for Jobs";
}

<div class="container">
    <div class="mb-5">
        <h2 class="fw-bold mb-2">Find Your Next Adventure 🚀</h2>
        <p class="text-muted">Browse through the latest job openings curated specifically for your profile.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card p-4 border-0 shadow-sm sticky-top" style="top: 100px;">
                <h5 class="fw-bold mb-3">Search Jobs</h5>
                <form method="get" action="/Candidate/ApplyJob/Index">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Keywords</label>
                        <input type="text" name="keyword" class="form-control" placeholder="Job title, Location..." value="@Context.Request.Query["keyword"]">
                    </div>
                    <button type="submit" class="btn btn-purple w-100">Search</button>
                    @if (!string.IsNullOrEmpty(Context.Request.Query["keyword"]))
                    {
                        <a href="/Candidate/ApplyJob" class="btn btn-outline-secondary w-100 mt-2">Clear</a>
                    }
                </form>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="row g-4">
                @if (Model != null && Model.Any())
                {
                    foreach (var job in Model)
                    {
                        <div class="col-12">
                            <div class="card p-4 border-0 shadow-sm">
                                <div class="d-flex justify-content-between align-items-start border-bottom pb-4 mb-4">
                                    <div class="d-flex gap-4">
                                        <div class="bg-primary bg-opacity-10 p-4 rounded-4 text-primary">
                                            <i class="bi bi-briefcase fs-1"></i>
                                        </div>
                                        <div>
                                            <h4 class="fw-bold mb-1">@job.Title</h4>
                                            <p class="text-muted mb-3">@job.CompanyName • (@job.Location)</p>
                                            <div class="d-flex gap-2">
                                                <span class="badge bg-light text-dark px-3 py-2 border">@job.Type</span>
                                                <span class="badge bg-light text-dark px-3 py-2 border">@job.SalaryRange</span>
                                            </div>
                                        </div>
                                    </div>
                                    <a href="/Candidate/ApplyJob/Details/@job.JobPositionId" class="btn btn-purple px-4 py-2">Apply Now</a>
                                </div>
                                <p class="text-muted">@(job.Description?.Length > 150 ? job.Description.Substring(0, 150) + "..." : job.Description)</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="text-muted small">Posted on @job.CreatedDate.ToString("MMM dd, yyyy")</div>
                                    <a href="/Candidate/ApplyJob/Details/@job.JobPositionId" class="text-decoration-none fw-bold" style="color: var(--cand-primary);">View Details <i class="bi bi-arrow-right"></i></a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <h4 class="text-muted">No jobs found matching your criteria.</h4>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
