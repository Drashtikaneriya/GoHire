@model List<RecruitmentsystemMVC.Models.CandidateApplicationItemViewModel>

@{
    ViewData["Title"] = "My Applications";
}

<div class="container py-5 min-vh-100 bg-light">
    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <h1 class="fw-bold text-dark display-5 mb-1">My Applications</h1>
            <p class="text-muted mb-0">Track the status of your current job applications.</p>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var app in Model)
            {
                <div class="col">
                    <div class="card border-0 shadow-lg rounded-4 overflow-hidden h-100 position-relative transition-hover">
                        <div class="card-header border-0 bg-white pt-4 px-4 pb-0">
                            <div class="d-flex justify-content-between align-items-start">
                                <span class="badge bg-light text-muted border px-2 py-1 small rounded-3">#@app.ApplicationId</span>
                                @{
                                    var badgeColor = "secondary";
                                    var currentStatus = app.Status ?? "Applied";
                                    if (currentStatus == "Applied" || currentStatus == "Pending") badgeColor = "warning text-dark";
                                    else if (currentStatus == "Shortlisted") badgeColor = "info text-white";
                                    else if (currentStatus == "Rejected") badgeColor = "danger text-white";
                                    else if (currentStatus == "Selected") badgeColor = "success text-white";
                                }
                                <span class="badge bg-@badgeColor rounded-pill px-3 py-2 shadow-sm">@currentStatus</span>
                            </div>
                        </div>
                        <div class="card-body px-4 pb-4 mt-3">
                            <h4 class="fw-bold text-dark mb-1">@app.JobTitle</h4>
                            <p class="text-secondary small mb-2"><i class="bi bi-building"></i> @app.CompanyName</p>
                            <div class="text-muted small mb-4">Applied on @app.AppliedOn.ToString("MMM dd, yyyy")</div>
                            
                            <div class="d-flex align-items-center p-3 bg-light rounded-3 mb-4">
                                <div class="rounded-circle bg-white border p-2 me-3 shadow-sm">
                                    <i class="bi bi-person-check fs-4"></i>
                                </div>
                                <div>
                                    <div class="text-muted small text-uppercase fw-bold" style="font-size: 0.65rem;">Candidate</div>
                                    <div class="fw-bold text-dark">@app.CandidateName</div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer border-0 bg-white p-4 pt-0">
                            <button onclick="ViewApplication(@app.ApplicationId)" class="btn btn-outline-primary w-100 rounded-pill py-2 fw-bold shadow-sm">
                                View Full Status <i class="bi bi-arrow-right-short ms-1"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm border mt-5">
            <div class="mb-4">
                <i class="bi bi-briefcase fs-1 text-muted opacity-25"></i>
            </div>
            <h3 class="fw-bold text-dark">No Applications Yet</h3>
            <p class="text-muted mx-auto" style="max-width: 400px;">Browse our open positions and start your journey with us today!</p>
            <a href="/Candidate/JobPosition" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow">Browse Jobs</a>
        </div>
    }
</div>

<div class="modal fade" id="appModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Application Journey</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 pt-2">
                <div id="appBody"></div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    function ViewApplication(id) {
        const body = document.getElementById('appBody');
        body.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary"></div></div>';
        const modal = new bootstrap.Modal(document.getElementById('appModal'));
        modal.show();

        fetch(`/Candidate/MyApplications/Get/${id}`)
            .then(r => r.json())
            .then(data => {
                body.innerHTML = `
                    <div class="p-3 bg-light rounded-4 mb-4 border-start border-4 border-primary shadow-sm">
                        <div class="fw-bold text-dark fs-5 mb-0">${data.jobTitle}</div>
                        <div class="text-muted small">ID: #${data.applicationId} | Applied On: ${new Date(data.appliedOn).toLocaleDateString()}</div>
                    </div>
                    <div class="px-2">
                        <div class="d-flex align-items-center mb-4">
                            <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
                            <div>
                                <div class="fw-bold fs-6">Status: <span class="text-info">${data.status}</span></div>
                                <div class="text-muted small">Our HR team is currently reviewing your profile.</div>
                            </div>
                        </div>
                        <div class="p-3 rounded-4 border bg-white small mb-2 shadow-sm">
                            <div class="fw-bold text-muted text-uppercase mb-2" style="font-size: 0.7rem;">Official Response / Notes</div>
                            <div class="text-dark">${data.hrNotes || "Your application is under evaluation. We'll update you soon!"}</div>
                        </div>
                    </div>
                `;
            });
    }
</script>

<style>
    .transition-hover { transition: transform 0.3s ease, shadow 0.3s ease; }
    .transition-hover:hover { transform: translateY(-8px); box-shadow: 0 1rem 3rem rgba(0,0,0,.15)!important; }
</style>
