@model RecruitmentsystemMVC.Models.DTOs.CandidateDTO

@{
    ViewData["Title"] = "My Profile";
}

<div class="container">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row g-4">
        <form method="post" action="/Candidate/Profile/Update" enctype="multipart/form-data" class="row g-4 m-0 p-0 w-100">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 text-center">
                    <div class="mx-auto mb-4 position-relative" style="width: 150px; height: 150px;">
                        <img src="https://ui-avatars.com/api/?name=@(Model?.FullName ?? Context.Session.GetString("UserName") ?? "Candidate")&background=6f42c1&color=fff&size=512" class="rounded-circle w-100 h-100 shadow">
                    </div>
                    <h4 class="fw-bold mb-1">@(Model?.FullName ?? Context.Session.GetString("UserName"))</h4>
                    <p class="text-muted">@(string.IsNullOrEmpty(Model?.Skills) ? "Aspiring Professional" : Model.Skills.Split(',').FirstOrDefault())</p>
                    <hr>
                    <div class="text-start">
                        <div class="mb-3">
                            <label class="text-muted small d-block mb-1">Full Name</label>
                            <input type="text" asp-for="FullName" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="text-muted small d-block mb-1">Email</label>
                            <input type="email" asp-for="Email" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="text-muted small d-block mb-1">Phone</label>
                            <input type="text" asp-for="Phone" class="form-control" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-purple w-100 mt-3 rounded-pill">Save Profile</button>
                </div>
            </div>
            
            <div class="col-md-8">
                <div class="card border-0 shadow-sm p-4 mb-4">
                    <h5 class="fw-bold mb-4">Professional Resume</h5>
                    @if (!string.IsNullOrEmpty(Model?.ResumeUrl))
                    {
                        <div class="d-flex align-items-center gap-4 bg-light p-4 rounded-4 mb-3">
                            <i class="bi bi-file-earmark-pdf-fill display-4 text-danger"></i>
                            <div class="flex-grow-1">
                                <h6 class="fw-bold mb-1">@System.IO.Path.GetFileName(Model.ResumeUrl)</h6>
                                <small class="text-muted">Currently Uploaded Resume</small>
                            </div>
                            <a href="@Model.ResumeUrl" target="_blank" class="btn btn-light rounded-pill"><i class="bi bi-download"></i> View</a>
                        </div>
                    }

                    <label class="form-label small fw-bold">Upload New Resume (PDF/DOC)</label>
                    <input type="file" name="ResumeFile" class="form-control" accept=".pdf,.doc,.docx" />
                </div>
                
                <div class="card border-0 shadow-sm p-4 text-start">
                    <h5 class="fw-bold mb-4">Experience & Skills</h5>
                    
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Experience summary</label>
                        <textarea asp-for="Experience" class="form-control" rows="4" placeholder="Briefly describe your experience..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Skills (comma separated)</label>
                        <input type="text" asp-for="Skills" class="form-control" placeholder="e.g. C#, .NET, React, SQL" />
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    .btn-outline-purple {
        border-color: var(--cand-primary);
        color: var(--cand-primary);
    }
    .btn-outline-purple:hover {
        background-color: var(--cand-primary);
        color: white;
    }
    .bg-purple, .btn-purple {
        background-color: var(--cand-primary);
        color: white;
    }
    .btn-purple:hover {
        background-color: #5a329c;
        color: white;
    }
</style>
