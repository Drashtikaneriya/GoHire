@model List<RecruitmentsystemMVC.Models.DTOs.InterviewResponseDTO>

@{
    ViewData["Title"] = "My Interviews";
}

<div class="container py-5 min-vh-100 bg-light">
    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <h1 class="fw-bold text-dark display-5 mb-1">My Interviews</h1>
            <p class="text-muted mb-0">Scheduled sessions and interview results (Read-only)</p>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var interview in Model)
            {
                <div class="col">
                    <div class="card border-0 shadow rounded-4 overflow-hidden h-100 transition-hover border-top border-4 border-info">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <span class="badge bg-light text-muted border px-2 py-1 small rounded-3">Entry #@interview.InterviewId</span>
                                @{
                                    var resColor = "secondary";
                                    if (interview.Result == "Passed") resColor = "success";
                                    else if (interview.Result == "Failed") resColor = "danger";
                                    else if (interview.Result == "Pending") resColor = "warning";
                                }
                                <span class="badge bg-@resColor rounded-pill px-3 py-1 shadow-sm small">@interview.Result</span>
                            </div>
                            
                            <h4 class="fw-bold text-dark mb-1">@interview.JobTitle</h4>
                            <div class="text-muted small mb-4">Official Session @interview.RoundNo</div>

                            <div class="p-3 bg-light rounded-3 mb-4 border border-light-subtle shadow-sm">
                                <div class="row g-2">
                                    <div class="col-12 mb-2 d-flex align-items-center">
                                        <i class="bi bi-calendar3 me-2 text-info"></i>
                                        <span class="fw-bold text-dark">@interview.InterviewDate.ToString("MMM dd, yyyy")</span>
                                    </div>
                                    <div class="col-12 d-flex align-items-center">
                                        <i class="bi bi-laptop me-2 text-info"></i>
                                        <span class="text-muted small">@interview.Mode</span>
                                    </div>
                                </div>
                            </div>

                            <button onclick="ViewFullResult(@interview.InterviewId)" class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow-sm mt-2">
                                Review Assessment Details <i class="bi bi-clipboard-check ms-1"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm border mt-5">
            <div class="mb-4">
                <i class="bi bi-calendar-x fs-1 text-muted opacity-25"></i>
            </div>
            <h3 class="fw-bold text-dark">No Scheduled Interviews</h3>
            <p class="text-muted mx-auto" style="max-width: 400px;">Interviews will appear once HR schedules a session for your shortlisted applications.</p>
        </div>
    }
</div>

<div class="modal fade" id="resModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Interview Assessment Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 pt-2">
                <div id="resBody"></div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    function ViewFullResult(id) {
        const body = document.getElementById('resBody');
        body.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary"></div></div>';
        const modal = new bootstrap.Modal(document.getElementById('resModal'));
        modal.show();

        fetch(`/Candidate/MyInterviews/GetDetails/${id}`)
            .then(r => r.json())
            .then(data => {
                const i = data.data;
                body.innerHTML = `
                    <div class="p-3 bg-light rounded-4 mb-4 border-start border-4 border-info shadow-sm d-flex align-items-center">
                        <div class="rounded-circle bg-white border p-3 me-3 fs-3 text-info shadow-sm">
                             <i class="bi bi-person-workspace"></i>
                        </div>
                        <div>
                             <div class="fw-bold text-dark fs-5 mb-0">${i.jobTitle ?? 'Job Position'}</div>
                             <div class="text-muted small">Session: Round ${i.roundNo} | Session Info: ${i.mode}</div>
                        </div>
                    </div>
                    <div class="px-2">
                        <div class="row g-4 mb-4 pt-3 border-top">
                            <div class="col-6">
                                <label class="small text-muted fw-bold text-uppercase d-block mb-1">Schedule Date</label>
                                <div class="fw-bold text-dark fs-6">${new Date(i.interviewDate).toLocaleDateString()}</div>
                            </div>
                            <div class="col-6">
                                <label class="small text-muted fw-bold text-uppercase d-block mb-1">Time (Local)</label>
                                <div class="fw-bold text-dark fs-6">${new Date(i.interviewDate).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</div>
                            </div>
                        </div>
                        <div class="p-3 rounded-4 border bg-white shadow-sm mb-3">
                            <div class="fw-bold text-muted text-uppercase mb-2" style="font-size: 0.7rem;">Official Final Outcome</div>
                            <div class="badge ${i.result === 'Passed' ? 'bg-success' : i.result === 'Failed' ? 'bg-danger' : 'bg-warning text-dark'} fs-6 px-1 py-1 rounded-pill w-100 text-center">${i.result}</div>
                        </div>
                        ${i.feedback ? `
                        <div class="p-3 rounded-4 border bg-white shadow-sm mb-2">
                            <div class="fw-bold text-muted text-uppercase mb-2" style="font-size: 0.7rem;">Interviewer Feedback</div>
                            <div class="text-dark small">${i.feedback}</div>
                        </div>` : ''}
                    </div>
                `;
            });
    }
</script>

<style>
    .transition-hover { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .transition-hover:hover { transform: scale(1.02); box-shadow: 0 1rem 3rem rgba(0,0,0,.15)!important; }
</style>
